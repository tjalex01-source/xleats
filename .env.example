# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Server-only. Used by cron jobs / the birthday matcher. NEVER expose to client.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Protects the cron endpoints (set the same value in Vercel cron headers)
CRON_SECRET=make-up-a-long-random-string

# Public base URL (used to build xleats.com/<slug> links)
NEXT_PUBLIC_SITE_URL=https://xleats.com

# Comma-separated emails allowed into /admin. Server-only check, never exposed
# to the client. Add every address that should have admin access.
ADMIN_EMAILS=you@example.com

# Google Cloud Console → APIs & Services → Credentials. Restrict this key to
# just the Geocoding API. Server-only — proxied via /api/geocode, never sent
# to the client.
GOOGLE_GEOCODING_API_KEY=YOUR-GEOCODING-KEY
